---

import Layout from "../layouts/Layout.astro";

---
<Layout title="One Stop Import Solutions" type="other" image="https://firebasestorage.googleapis.com/v0/b/dragoninnovation-ea771.appspot.com/o/00%20Primary.jpg?alt=media&token=d6544990-c28d-409a-b176-35fab72eb7e8"
        description="Start your import business with Dragon Innovation — consultation, brand sourcing, import licensing and FDA, payments, logistics and marketing in one place.">

    <!-- /hero -->
    <section class="wrapper bg-soft-primary">
        <div class="container pt-14 pt-md-16 pb-12 pb-md-14 text-center">
            <div class="row" data-cues="slideInDown" data-group="page-title" data-delay="300">
                <div class="col-md-10 col-lg-8 mx-auto">
                    <h2 class="fs-16 text-uppercase text-primary mb-3">Our Services</h2>
                    <h1 class="display-2 mb-4">One Stop <span class="text-gradient gradient-1">Import</span> Solutions</h1>
                    <p class="lead fs-lg mb-4">Start an import business with us — everything you need from first consultation to market placement, in one place.</p>
                    <p class="mb-8 px-lg-8">လူကြီးမင်းတို့အနေနဲ့ ကိုယ်ပိုင်လုပ်ငန်းတစ်ခုကို လျင်မြန်ချောမွေ့စွာ စတင်ဖို့စီစဉ်နေပြီလား? နိုင်ငံတကာမှ နာမည်ကျော် အလှကုန်နှင့် လူသုံးကုန်ပစ္စည်းများကို တင်သွင်းရောင်းချပြီး ကိုယ်ပိုင်စီးပွားရေးလုပ်ငန်းတစ်ခုကို ခိုင်မာစွာအကောင်အထည်ဖော်လိုသူများအတွက် Dragon Innovation ကုမ္ပဏီနှင့်အတူ လက်တွဲကြရအောင်။</p>
                    <a href="/#contact" class="btn btn-lg btn-primary rounded-pill">Start Your Import Business</a>
                </div>
                <!-- /column -->
            </div>
            <!-- /.row -->
        </div>
        <!-- /.container -->
    </section>

    <!-- /services -->
    <section class="wrapper bg-light">
        <div class="container py-14 py-md-16">
            <div class="row text-center" data-cue="slideInDown">
                <div class="col-md-10 offset-md-1 col-lg-8 offset-lg-2">
                    <h2 class="fs-16 text-uppercase text-muted mb-3">What We Do</h2>
                    <h3 class="display-4 mb-10 px-xl-10">A complete import journey — six services, one trusted partner.</h3>
                </div>
                <!-- /column -->
            </div>
            <div class="row gx-md-8 gy-8" data-cues="slideInUp" data-group="import-services" data-delay="150">
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-lg lift h-100">
                        <div class="card-body">
                            <div class="mb-4"><span class="badge bg-pale-primary text-primary rounded-pill">Step 1</span></div>
                            <img src="/assets/img/icons/lineal/telephone-3.svg" class="svg-inject icon-svg icon-svg-md text-yellow mb-3" alt="" />
                            <h4>Consultation</h4>
                            <p class="mb-0">အလှကုန်တင်သွင်းရန်လိုအပ်သောလုပ်ငန်းပိုင်းဆိုင်ရာများအား အသေးစိတ်ဆွေးနွေးပေးခြင်း။ တင်သွင်းရောင်းချလိုသည့် အမှတ်တံဆိပ်များကိုလည်း Dragon Innovation Company မှ ကူညီရှာဖွေဆောင်ရွက်ပေးခြင်း။</p>
                        </div>
                        <!--/.card-body -->
                    </div>
                    <!--/.card -->
                </div>
                <!--/column -->
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-lg lift h-100">
                        <div class="card-body">
                            <div class="mb-4"><span class="badge bg-pale-primary text-primary rounded-pill">Step 2</span></div>
                            <img src="/assets/img/icons/lineal/check-list.svg" class="svg-inject icon-svg icon-svg-md text-primary mb-3" alt="" />
                            <h4>Import Licence &amp; Documents</h4>
                            <p class="mb-0">တင်သွင်းရန် Import License မှစ၍ FDA ရရှိသည်အထိ တာဝန်ယူဆောင်ရွက်ပေးခြင်း။ Online Sales Registration နှင့် “ပသခ” လျှောက်ပေးခြင်း။</p>
                        </div>
                        <!--/.card-body -->
                    </div>
                    <!--/.card -->
                </div>
                <!--/column -->
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-lg lift h-100">
                        <div class="card-body">
                            <div class="mb-4"><span class="badge bg-pale-primary text-primary rounded-pill">Step 3</span></div>
                            <img src="/assets/img/icons/lineal/money.svg" class="svg-inject icon-svg icon-svg-md text-red mb-3" alt="" />
                            <h4>Payments</h4>
                            <p class="mb-0">နိုင်ငံတကာ ပေးချေမှုများအပါအဝင် ငွေပေးငွေချေကိစ္စများကို လုံခြုံစိတ်ချစွာ ဆောင်ရွက်ပေးခြင်း။</p>
                        </div>
                        <!--/.card-body -->
                    </div>
                    <!--/.card -->
                </div>
                <!--/column -->
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-lg lift h-100">
                        <div class="card-body">
                            <div class="mb-4"><span class="badge bg-pale-primary text-primary rounded-pill">Step 4</span></div>
                            <img src="/assets/img/icons/lineal/truck.svg" class="svg-inject icon-svg icon-svg-md text-leaf mb-3" alt="" />
                            <h4>Logistics Service</h4>
                            <p class="mb-0">ကုန်ပစ္စည်းများ မြန်မာပြည်အရောက် ပို့ဆောင်ပေးနိုင်သော ယုံကြည်စိတ်ချရသည့် Logistics ကုမ္ပဏီများနှင့် ချိတ်ဆက်ဆောင်ရွက်ပေးခြင်း (air freight / sea freight / cargo)။</p>
                        </div>
                        <!--/.card-body -->
                    </div>
                    <!--/.card -->
                </div>
                <!--/column -->
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-lg lift h-100">
                        <div class="card-body">
                            <div class="mb-4"><span class="badge bg-pale-primary text-primary rounded-pill">Step 5</span></div>
                            <img src="/assets/img/icons/lineal/analytics.svg" class="svg-inject icon-svg icon-svg-md text-purple mb-3" alt="" />
                            <h4>Branding &amp; Marketing</h4>
                            <p class="mb-0">ကြော်ငြာလုပ်ငန်းများ ဆောင်ရွက်ခြင်းနှင့် ဈေးကွက်အတွင်း ပစ္စည်းများ ဖြန့်ချိရောင်းချခြင်းများအတွက် ဝန်ဆောင်မှုရယူနိုင်ခြင်း။</p>
                        </div>
                        <!--/.card-body -->
                    </div>
                    <!--/.card -->
                </div>
                <!--/column -->
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-lg lift h-100">
                        <div class="card-body">
                            <div class="mb-4"><span class="badge bg-pale-primary text-primary rounded-pill">Step 6</span></div>
                            <img src="/assets/img/icons/lineal/shop-2.svg" class="svg-inject icon-svg icon-svg-md text-pink mb-3" alt="" />
                            <h4>Product Placement in Markets</h4>
                            <p class="mb-0">မြန်မာပြည်ဈေးကွက်ထဲတွင် နာမည်ရအမှတ်တံဆိပ်တစ်ခုအဖြစ် ရပ်တည်နိုင်ရန် Online, Offline Marketing Team များဖြင့် ဆောင်ရွက်ပေးခြင်း။</p>
                        </div>
                        <!--/.card-body -->
                    </div>
                    <!--/.card -->
                </div>
                <!--/column -->
            </div>
            <!-- /.row -->
        </div>
        <!-- /.container -->
    </section>

    <!-- /community + CTA -->
    <section class="wrapper image-wrapper bg-auto no-overlay bg-image text-center bg-map" data-image-src="/assets/img/map.png">
        <div class="container pt-0 pb-14 pt-md-14 pb-md-16">
            <div class="row" data-cue="slideInDown">
                <div class="col-lg-10 col-xl-9 col-xxl-8 mx-auto">
                    <h2 class="fs-16 text-uppercase text-muted mb-3">Join Our Community</h2>
                    <h3 class="display-4 mb-8 px-lg-12">Trusted by partners and customers across Myanmar. Join them and grow your business.</h3>
                </div>
                <!-- /column -->
            </div>
            <!-- /.row -->
            <div class="row" data-cue="slideInUp">
                <div class="col-md-10 col-lg-9 col-xl-7 mx-auto">
                    <div class="row align-items-center counter-wrapper gy-4 gy-md-0 mb-10">
                        <div class="col-md-4 text-center">
                            <h3 class="counter counter-lg text-primary">112+</h3>
                            <p>Retailers</p>
                        </div>
                        <!--/column -->
                        <div class="col-md-4 text-center">
                            <h3 class="counter counter-lg text-primary">13238+</h3>
                            <p>Happy Customers</p>
                        </div>
                        <!--/column -->
                        <div class="col-md-4 text-center">
                            <h3 class="counter counter-lg text-primary">162+</h3>
                            <p>Good Reviews</p>
                        </div>
                        <!--/column -->
                    </div>
                    <!--/.row -->
                    <a href="/#contact" class="btn btn-lg btn-primary rounded-pill">Get In Touch</a>
                </div>
                <!-- /column -->
            </div>
            <!-- /.row -->
        </div>
        <!-- /.container -->
    </section>
</Layout>
