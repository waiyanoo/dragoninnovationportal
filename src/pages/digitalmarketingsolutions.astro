---

import Layout from "../layouts/Layout.astro";

---
<Layout title="Digital Marketing Solutions" type="other" image="https://firebasestorage.googleapis.com/v0/b/dragoninnovation-ea771.appspot.com/o/00%20Primary.jpg?alt=media&token=d6544990-c28d-409a-b176-35fab72eb7e8"
        description="Professional digital marketing for the Myanmar market — campaigns, social media, live commerce, brand localization, retail activation and analytics by Dragon Innovation.">

    <!-- /hero -->
    <section class="wrapper bg-soft-primary">
        <div class="container pt-14 pt-md-16 pb-12 pb-md-14 text-center">
            <div class="row" data-cues="slideInDown" data-group="page-title" data-delay="300">
                <div class="col-md-10 col-lg-8 mx-auto">
                    <h2 class="fs-16 text-uppercase text-primary mb-3">Our Services</h2>
                    <h1 class="display-2 mb-4">Digital <span class="text-gradient gradient-1">Marketing</span> Solutions</h1>
                    <p class="lead fs-lg mb-8 px-lg-5">We localize global brands for Myanmar's consumers — creative campaigns, social media, live commerce and retail activation, all run by our professional in-house marketing team.</p>
                    <a href="/#contact" class="btn btn-lg btn-primary rounded-pill">Get a Marketing Proposal</a>
                </div>
                <!-- /column -->
            </div>
            <!-- /.row -->
        </div>
        <!-- /.container -->
    </section>

    <!-- /services -->
    <section class="wrapper bg-light">
        <div class="container py-14 py-md-16">
            <div class="row text-center" data-cue="slideInDown">
                <div class="col-md-10 offset-md-1 col-lg-8 offset-lg-2">
                    <h2 class="fs-16 text-uppercase text-muted mb-3">What We Do</h2>
                    <h3 class="display-4 mb-10 px-xl-10">Everything your brand needs to win the Myanmar market.</h3>
                </div>
                <!-- /column -->
            </div>
            <div class="row gx-md-8 gy-8" data-cues="slideInUp" data-group="marketing-services" data-delay="150">
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-lg lift h-100">
                        <div class="card-body">
                            <img src="/assets/img/icons/lineal/megaphone.svg" class="svg-inject icon-svg icon-svg-md text-purple mb-3" alt="" />
                            <h4>Digital Campaigns</h4>
                            <p class="mb-0">Creative campaign strategy and paid advertising across the social channels Myanmar consumers use every day.</p>
                        </div>
                        <!--/.card-body -->
                    </div>
                    <!--/.card -->
                </div>
                <!--/column -->
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-lg lift h-100">
                        <div class="card-body">
                            <img src="/assets/img/icons/lineal/chat-2.svg" class="svg-inject icon-svg icon-svg-md text-primary mb-3" alt="" />
                            <h4>Social Media Management</h4>
                            <p class="mb-0">Content creation, page management and community engagement that build loyal audiences for your brand.</p>
                        </div>
                        <!--/.card-body -->
                    </div>
                    <!--/.card -->
                </div>
                <!--/column -->
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-lg lift h-100">
                        <div class="card-body">
                            <img src="/assets/img/icons/lineal/microphone.svg" class="svg-inject icon-svg icon-svg-md text-red mb-3" alt="" />
                            <h4>Live Commerce</h4>
                            <p class="mb-0">Live selling sessions and shoppable streams that turn viewers into customers in real time.</p>
                        </div>
                        <!--/.card-body -->
                    </div>
                    <!--/.card -->
                </div>
                <!--/column -->
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-lg lift h-100">
                        <div class="card-body">
                            <img src="/assets/img/icons/lineal/design.svg" class="svg-inject icon-svg icon-svg-md text-yellow mb-3" alt="" />
                            <h4>Brand Localization</h4>
                            <p class="mb-0">Adapting your brand's story, content and creative for Myanmar's language, culture and shopping habits.</p>
                        </div>
                        <!--/.card-body -->
                    </div>
                    <!--/.card -->
                </div>
                <!--/column -->
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-lg lift h-100">
                        <div class="card-body">
                            <img src="/assets/img/icons/lineal/shop-2.svg" class="svg-inject icon-svg icon-svg-md text-pink mb-3" alt="" />
                            <h4>Retail Activation</h4>
                            <p class="mb-0">In-store campaigns, product launches and events that connect your brand with shoppers nationwide.</p>
                        </div>
                        <!--/.card-body -->
                    </div>
                    <!--/.card -->
                </div>
                <!--/column -->
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-lg lift h-100">
                        <div class="card-body">
                            <img src="/assets/img/icons/lineal/analytics.svg" class="svg-inject icon-svg icon-svg-md text-leaf mb-3" alt="" />
                            <h4>Market Insights &amp; Analytics</h4>
                            <p class="mb-0">Local market intelligence and transparent performance reporting, so every decision is backed by data.</p>
                        </div>
                        <!--/.card-body -->
                    </div>
                    <!--/.card -->
                </div>
                <!--/column -->
            </div>
            <!-- /.row -->
        </div>
        <!-- /.container -->
    </section>

    <!-- /community + CTA -->
    <section class="wrapper image-wrapper bg-auto no-overlay bg-image text-center bg-map" data-image-src="/assets/img/map.png">
        <div class="container pt-0 pb-14 pt-md-14 pb-md-16">
            <div class="row" data-cue="slideInDown">
                <div class="col-lg-10 col-xl-9 col-xxl-8 mx-auto">
                    <h2 class="fs-16 text-uppercase text-muted mb-3">Join Our Community</h2>
                    <h3 class="display-4 mb-8 px-lg-12">Trusted by partners and customers across Myanmar. Join them and grow your brand.</h3>
                </div>
                <!-- /column -->
            </div>
            <!-- /.row -->
            <div class="row" data-cue="slideInUp">
                <div class="col-md-10 col-lg-9 col-xl-7 mx-auto">
                    <div class="row align-items-center counter-wrapper gy-4 gy-md-0 mb-10">
                        <div class="col-md-4 text-center">
                            <h3 class="counter counter-lg text-primary">112+</h3>
                            <p>Retailers</p>
                        </div>
                        <!--/column -->
                        <div class="col-md-4 text-center">
                            <h3 class="counter counter-lg text-primary">13238+</h3>
                            <p>Happy Customers</p>
                        </div>
                        <!--/column -->
                        <div class="col-md-4 text-center">
                            <h3 class="counter counter-lg text-primary">162+</h3>
                            <p>Good Reviews</p>
                        </div>
                        <!--/column -->
                    </div>
                    <!--/.row -->
                    <a href="/#contact" class="btn btn-lg btn-primary rounded-pill">Get In Touch</a>
                </div>
                <!-- /column -->
            </div>
            <!-- /.row -->
        </div>
        <!-- /.container -->
    </section>
</Layout>
