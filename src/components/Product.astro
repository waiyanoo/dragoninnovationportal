---
export interface ProductModel{
    id: string
    imgUrls: string[]
    category: string
    productName: string
    shortDescription: string
    description: string
    price: string
    discountPrice: string
    sales: boolean
    new: boolean
    page: string
    sizes: string[]
    messenger: string
    publicImg: string
}

export interface Props{
    data: ProductModel,
    path: string
}

const {data, path} = Astro.props;

---

<div class="project item col-6 col-md-4 col-xl-3">
    <div class="card product-card shadow-lg lift h-100 overflow-hidden">
        <figure class="card-img-top hover-scale ratio ratio-1x1 bg-white mb-0">
            <img class="product-img" src={path + data.imgUrls[0]} alt={data.productName} loading="lazy" />
        </figure>
        <div class="product-badges position-absolute d-flex flex-column gap-1">
            {data.sales && <span class="badge rounded-pill bg-pink text-white">Sale</span>}
            {data.new && <span class="badge rounded-pill bg-aqua text-white">New</span>}
        </div>
        <div class="card-body p-4">
            <div class="post-category text-ash fs-13 mb-1">{data.category}</div>
            <h2 class="post-title product-title fs-16 mb-2"><a href={data.page} class="link-dark stretched-link">{data.productName}</a></h2>
            <div class="d-flex flex-row align-items-center justify-content-between">
                {data.sales && <p class="price fs-15 mb-0"><del><span class="amount">{data.price}</span></del> <ins><span class="amount">{data.discountPrice}</span></ins></p>}
                {!data.sales && <p class="price fs-15 mb-0"><span class="amount">{data.price}</span></p>}
                <span class="price-duration fs-13">{data.sizes[0]}</span>
            </div>
        </div>
        <!--/.card-body -->
    </div>
    <!--/.card -->
</div>

<style>
    .product-card {
        border-radius: 0.8rem;
    }
    .product-img {
        object-fit: contain;
        padding: 1rem;
    }
    .product-badges {
        top: 0.75rem;
        left: 0.75rem;
        z-index: 2;
    }
    .product-title {
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
        overflow: hidden;
        min-height: 2.8em;
        line-height: 1.4;
    }
</style>
